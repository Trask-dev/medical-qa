# ---- LLM ----
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-flash

# ---- Embedding ----
EMBEDDING_API_KEY=your-embedding-api-key-here
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
BGE_MODEL_PATH=/path/to/your/bge-model

# ---- PostgreSQL ----
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5433/medical_qa

# ---- 向量存储 ----
VECTOR_BACKEND=pgvector

# ---- HuggingFace ----
HF_HUB_OFFLINE=0

# ---- 安全 ----
ENCRYPTION_KEY=change-me-to-a-random-32-byte-hex-string
JWT_SECRET=change-me-to-a-random-64-byte-hex-string
LOG_LEVEL=INFO

# === 生成密钥命令 ===
# JWT_SECRET: python -c "import secrets; print(secrets.token_hex(64))"
# ENCRYPTION_KEY: python -c "import secrets; print(secrets.token_hex(32))"